# SAGE ENVIRONMENT CONFIGURATION TEMPLATE

# 1. Runtime settings
DEBUG=True
LOG_LEVEL=INFO

# 2. Storage Settings
# Options: 'local' (for file-based persistent disk storage) or 'in-memory' (for mock/ephemeral runtimes)
MEMORY_BACKEND=local
ARCHIVE_BACKEND=local

# 3. Security Settings
# API key authorized to invoke secure REST endpoints (e.g. /service/startup, /service/shutdown, /ingest)
SAGE_API_KEYS=["your-custom-secure-api-key"]

# 4. Google Workspace Sync credentials path
GOOGLE_APPLICATION_CREDENTIALS=.sage/credentials.json
