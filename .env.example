# SAGE Runtime Environment Configuration Example
# Copy this file to '.env' and populate the required API keys and credentials.

# ----------------------------------------
# 1. Core Runtime Settings
# ----------------------------------------
DEBUG=False
LOG_LEVEL=INFO
MAX_RETRIES=3

# ----------------------------------------
# 2. Storage Settings
# ----------------------------------------
# Supported backends: 'in-memory' or 'local-json'
MEMORY_BACKEND=in-memory
ARCHIVE_BACKEND=in-memory

# ----------------------------------------
# 3. Autonomous Continuity Runtime (ACR)
# ----------------------------------------
ENABLE_CONTINUITY=True
CONTINUITY_TIMEOUT=3600

# ----------------------------------------
# 4. REST API & Service Security
# ----------------------------------------
# Comma-separated list of authorized API keys for administrative/service routes
SAGE_API_KEYS=sage-default-key-2026,another-secret-key-9988

# ----------------------------------------
# 5. External AI Connector API Keys (Optional)
# ----------------------------------------
# Required for live ChatGPT and Gemini/Jules model query execution
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ----------------------------------------
# 6. Engineering Tool Integrations (Optional)
# ----------------------------------------
# Credentials and webhooks configuration
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here
GOOGLE_CLOUD_OAUTH_CLIENT_ID=your-google-oauth-client-id-here
GOOGLE_CLOUD_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret-here
