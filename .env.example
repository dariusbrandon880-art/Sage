# SAGE RUNTIME ENVIRONMENTAL CONFIGURATION TEMPLATE
# Copy this file to .env and configure secret keys for live deployment.

# --- Core Service Settings ---
ENV=production
DEBUG=false
LOG_LEVEL=INFO
PORT=8000
HOST=0.0.0.0

# --- SAGE Authentication Boundary ---
# Comma-separated list of authorized API keys for Header: x-api-key
SAGE_API_KEYS=your-secret-prod-key-1,your-secret-prod-key-2
# Set to true to enforce x-api-key authentication on ALL API endpoints (highly recommended for live deployment)
SAGE_REQUIRE_AUTH=false

# --- Subsystem Backends ---
# Supported options: in-memory, disk
MEMORY_BACKEND=disk
ARCHIVE_BACKEND=disk

# --- Autonomous Continuity Settings ---
ENABLE_CONTINUITY=true
CONTINUITY_TIMEOUT=3600

# --- Google Workspace Synchronization ---
# Path to your Google OAuth desktop application credential JSON file
GOOGLE_WORKSPACE_CREDENTIALS_PATH=.sage/credentials.json

# --- GitHub Event Integration ---
# Secure secret to validate GitHub Webhook payloads (matches GitHub Webhook Secret)
GITHUB_WEBHOOK_SECRET=your-github-webhook-hmac-secret-here
# Optional GitHub personal access token for repository write-back
GITHUB_ACCESS_TOKEN=your-github-pat-here

# --- Gemini / Jules Agent Settings ---
# Google AI Studio API key for Gemini models
GEMINI_API_KEY=your-gemini-api-key-here
